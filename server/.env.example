# Copie en .env pour le développement local.
# PostgreSQL local (ou l'External Connection String fournie par Render).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/afc?schema=public"

# Secret pour signer les JWT (mettre une longue chaîne aléatoire en prod).
JWT_SECRET="dev-secret-change-me"

# Compte staff par défaut créé par le seed.
ADMIN_EMAIL="admin@afc.local"
ADMIN_PASSWORD="admin1234"

# Port de l'API (Render fournit automatiquement PORT en prod).
PORT=4000
